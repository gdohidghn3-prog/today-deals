# 카카오 REST API 키 (주변 매장 찾기 기능)
# 발급: https://developers.kakao.com → 앱 생성 → 앱 키 → REST API 키
# 활성화 필요: 카카오 디벨로퍼스 → 내 애플리케이션 → 앱 설정 → 플랫폼 → Web 도메인 등록
# 사용 API: 로컬 - 카테고리로 장소 검색 (CS2 = 편의점)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# 오피넷(한국석유공사) 유가정보 API 키 (주유 최저가 기능)
# 발급: https://www.opinet.co.kr → 회원가입 → 유가관련정보 → 유가정보 API 신청 (무료)
# 사용 API: avgAllPrice (전국평균), avgSidoPrice (시도평균), aroundAll (반경검색), lowTop10 (최저가)
OPINET_API_KEY=your_opinet_api_key_here

# 서울 열린데이터광장 API 키 (무료 문화행사 기능)
# 발급: https://data.seoul.go.kr → 회원가입 → 인증키 발급 (무료, 즉시)
# 미설정 시 sample 키 사용 (5건 제한)
SEOUL_OPENAPI_KEY=your_seoul_openapi_key_here

# 한국관광공사 + 한국문화정보원 API 키 (전국 축제/행사 + 공연/전시 기능)
# 발급: https://data.go.kr → 한국관광공사_국문 관광정보 서비스_GW + 공연전시 정보 조회서비스 활용신청 (무료)
# 미설정 시 서울 데이터만 표시
DATA_GO_KR_API_KEY=your_data_go_kr_api_key_here
